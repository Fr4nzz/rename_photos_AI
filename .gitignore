# Ignorar todos los archivos
*

# Pero no ignorar archivos .py (en cualquier directorio)
!*.py
!**/*.py

# No ignorar directorios para poder acceder a archivos .py dentro
!*/

# No ignorar el archivo .gitignore
!.gitignore

# No ignorar requirements.txt
!requirements.txt

# No ignorar README.md
!README.md

# No ignorar build.spec
!build.spec

# No ignorar icons folder (app icons for all platforms)
!icons/
!icons/*.ico
!icons/*.svg
!icons/*.icns

# No ignorar screenshots necesarios para README
!screenshots/
!screenshots/*.png

# Ignorar carpeta dist y build
dist/
build/

# --- Web App ---
# Include web-app source files
!web-app/
!web-app/**/*.ts
!web-app/**/*.tsx
!web-app/**/*.css
!web-app/**/*.html
!web-app/**/*.json
!web-app/**/*.js
!web-app/**/*.yml
!web-app/**/*.yaml
!web-app/**/*.svg
!web-app/**/.gitkeep

# Exclude web-app build artifacts and dependencies
web-app/node_modules/
web-app/dist/
web-app/backend/node_modules/
web-app/backend/dist/
web-app/backend/bin/exiftool*
!web-app/backend/bin/.gitkeep

# --- GitHub Actions ---
!.github/
!.github/**/*.yml