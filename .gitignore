# Ignorar todos los archivos
*

# Pero no ignorar archivos .py (en cualquier directorio)
!*.py
!**/*.py

# No ignorar directorios para poder acceder a archivos .py dentro
!*/

# No ignorar el archivo .gitignore
!.gitignore

# No ignorar requirements.txt
!requirements.txt

# No ignorar README.md
!README.md

# No ignorar build.spec
!build.spec

# No ignorar icons folder (app icons for all platforms)
!icons/
!icons/*.ico
!icons/*.svg
!icons/*.icns

# No ignorar screenshots necesarios para README
!screenshots/
!screenshots/*.png

# Ignorar carpeta dist y build
dist/
build/ 